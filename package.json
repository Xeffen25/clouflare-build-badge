{
  "name": "cloudflare-build-badge",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "wrangler types && astro dev",
    "build": "astro build",
    "preview": "pnpm build && astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "pnpm build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "github:ci": "pnpm format:check && astro check && pnpm test",
    "all": "pnpm format && pnpm cf-typegen && astro check && pnpm test && pnpm build",
    "machine-translate": "inlang machine translate --project project.inlang"
  },
  "lint-staged": {
    "*": "prettier --write"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.0",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.6",
    "eminence-astro-suite": "1.0.0-beta.11",
    "sharp": "^0.35.3",
    "sharp-ico": "^0.1.5",
    "svelte": "^5.56.4",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@inlang/cli": "^3.1.14",
    "@inlang/paraglide-js": "^2.20.2",
    "@types/node": "^26.1.0",
    "daisyui": "^5.6.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^4.1.1",
    "schema-dts": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}
