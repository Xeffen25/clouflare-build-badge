---
import DefaultLayout from "@/layouts/DefaultLayout.astro";
import { m } from "@/paraglide/messages";
import Configurator from "@/pages/_index/Configurator.svelte";
import Examples from "@/pages/_index/Examples.astro";
import About from "@/pages/_index/About.astro";
import HowItWorks from "@/pages/_index/HowItWorks.astro";
import DeployGuide from "@/pages/_index/DeployGuide.astro";
---

<DefaultLayout title={m.index_title()} description={m.index_description()}>
  <Configurator client:load />
  <Examples />
  <About />
  <HowItWorks />
  <DeployGuide />
</DefaultLayout>
