---
import { m } from "@/paraglide/messages";
---

<section id="about" class="page-container py-12 sm:py-20">
  <h2 class="text-accent text-2xl font-bold sm:text-3xl">
    {m.about_title()}
  </h2>
  <p class="text-base-content/80 mt-4 max-w-2xl leading-relaxed">
    {m.about_what_text()}
  </p>

  <h3 class="text-accent mt-8 text-xl font-semibold">
    {m.about_problem_title()}
  </h3>
  <p class="text-base-content/80 mt-2 max-w-2xl leading-relaxed">
    {m.about_problem_text()}
  </p>
</section>
