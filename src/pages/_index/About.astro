---
import { m } from "@/paraglide/messages";
---

<section id="about" class="page-container section-padding">
  <h2>{m.about_title()}</h2>
  <p class="text-base-content/80 mx-auto mt-4 max-w-2xl leading-relaxed">
    {m.about_what_text()}
  </p>

  <h3 class="mt-12">{m.about_problem_title()}</h3>
  <p class="text-base-content/80 mx-auto mt-2 max-w-2xl leading-relaxed">
    {m.about_problem_text()}
  </p>
</section>
