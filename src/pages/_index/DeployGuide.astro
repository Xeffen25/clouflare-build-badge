---
import { m } from "@/paraglide/messages";
import CardStepTitle from "@/components/CardStepTitle.svelte";
import CopyableCode from "@/components/CopyableCode.svelte";
import SectionHeading from "@/components/SectionHeading.svelte";

const deployStep1Command = m.deploy_step1_command();
const deploySecretCommand = m.deploy_step5_command();
const deployCommitCommand1 = m.deploy_step6_command_1();
const deployCommitCommand2 = m.deploy_step6_command_2();
---

<section id="deploy" class="page-container py-12 sm:py-20">
  <SectionHeading>{m.deploy_title()}</SectionHeading>
  <p class="text-base-content/70 mt-2 max-w-2xl">{m.deploy_description()}</p>

  <ol class="mt-8 flex flex-col gap-4">
    <li class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <CardStepTitle align="left">{m.deploy_step1_label()}</CardStepTitle>
        <p class="text-base-content/70 text-sm">{m.deploy_step1_text()}</p>
        <CopyableCode
          client:visible
          text={deployStep1Command}
          label={m.common_copy_command()}
          copiedLabel={m.common_copied()}
        />
      </div>
    </li>

    <li class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <CardStepTitle align="left">{m.deploy_step2_label()}</CardStepTitle>
        <p class="text-base-content/70 text-sm">{m.deploy_step2_text()}</p>
        <a
          href="https://dash.cloudflare.com/"
          target="_blank"
          rel="noopener"
          class="link link-primary text-sm"
        >
          {m.deploy_step2_link_label()}
        </a>
      </div>
    </li>

    <li class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <CardStepTitle align="left">{m.deploy_step3_label()}</CardStepTitle>
        <p class="text-base-content/70 text-sm">{m.deploy_step3_text()}</p>
      </div>
    </li>

    <li class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <CardStepTitle align="left">{m.deploy_step4_label()}</CardStepTitle>
        <p class="text-base-content/70 text-sm">{m.deploy_step4_text_a()}</p>
        <p class="text-base-content/70 text-sm">{m.deploy_step4_text_b()}</p>
      </div>
    </li>

    <li class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <CardStepTitle align="left">{m.deploy_step5_label()}</CardStepTitle>
        <p class="text-base-content/70 text-sm">{m.deploy_step5_text()}</p>
        <a
          href="https://github.com/settings/tokens/new"
          target="_blank"
          rel="noopener"
          class="link link-primary text-sm"
        >
          {m.deploy_step5_link_label()}
        </a>
        <CopyableCode
          client:visible
          text={deploySecretCommand}
          label={m.common_copy_command()}
          copiedLabel={m.common_copied()}
        />
      </div>
    </li>

    <li class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <CardStepTitle align="left">{m.deploy_step6_label()}</CardStepTitle>
        <p class="text-base-content/70 text-sm">{m.deploy_step6_text()}</p>
        <CopyableCode
          client:visible
          text={deployCommitCommand1}
          label={m.common_copy_command()}
          copiedLabel={m.common_copied()}
        />
        <CopyableCode
          client:visible
          text={deployCommitCommand2}
          label={m.common_copy_command()}
          copiedLabel={m.common_copied()}
        />
      </div>
    </li>
  </ol>
</section>
